{
  "name": "family-finance-tracker",
  "version": "1.0.0",
  "description": "Family Finance Expense Tracker with AI-powered insights",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd apps/backend && npm run dev",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd apps/backend && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd apps/backend && npm test",
    "test:frontend": "cd apps/frontend && npm test",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd apps/backend && npm run lint",
    "lint:frontend": "cd apps/frontend && npm run lint",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "prisma:migrate": "cd apps/backend && npm run prisma:migrate",
    "prisma:seed": "cd apps/backend && npm run prisma:seed",
    "prisma:studio": "cd apps/backend && npm run prisma:studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/family-finance-tracker.git"
  },
  "keywords": [
    "finance",
    "expense-tracker",
    "family",
    "ai",
    "react",
    "typescript",
    "nodejs"
  ],
  "author": "Family Finance Tracker Team",
  "license": "MIT"
}

